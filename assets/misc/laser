            //this function define the size of the items
            function ResCarouselSize() {
                var incno = 0;
                var dataItems = ("data-items");
                var itemClass = ('.item');
                var id = 0;
                var btnParentSb = '';
                var itemsSplit = '';
                var sampwidth = $(itemsMainDiv).width();
                var bodyWidth = $('body').width();
                $(itemsDiv).each(function () {
                    id = id + 1;
                    var itemNumbers = $(this).find(itemClass).length;
                    console.log(itemNumbers);
                    // let leftMove = $(this).closest('.MultiCarousel');
                    let leftMove = $(this).parent().find('.leftLst');
                    let rightMove = $(this).parent().find('.rightLst');
                    btnParentSb = $(this).parent().attr(dataItems);
                    itemsSplit = btnParentSb.split(',');
                    $(this).parent().attr("id", "MultiCarousel" + id);


                    if (bodyWidth >= 1024 && itemNumbers > 6) {
                        console.log(bodyWidth)
                        console.log('> 6');
                        incno = itemsSplit[2];
                        itemWidth = sampwidth / incno;
                    }
                    else if (bodyWidth < 1024 && bodyWidth > 768 && itemNumbers > 4) {
                        console.log(bodyWidth)
                        // alert('> 4');
                        incno = itemsSplit[1];
                        itemWidth = sampwidth / incno;
                    }
                    else if (bodyWidth <= 768 && itemNumbers > 3) {
                        console.log(bodyWidth)
                        console.log('> 3');
                        incno = itemsSplit[0];
                        itemWidth = sampwidth / incno;
                    }
                    else {
                        console.log(bodyWidth)
                        // alert('none');
                        itemWidth = sampwidth / itemNumbers;
                        leftMove.css('display', 'none');
                        rightMove.css('display', 'none');
                    }
                    $(this).css({ 'transform': 'translateX(0px)', 'width': itemWidth * itemNumbers });
                    $(this).find(itemClass).each(function () {
