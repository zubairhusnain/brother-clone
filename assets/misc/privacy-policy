    function LogOutUser() {
        var d = new Date();
        var time = d.getHours() + ":" + d.getMinutes() + ":" + d.getSeconds();
        //var editURL = "/api/cxa/loginform/logoutuser";
        var editURL = "/api/user/loginform/signoutuser";
        editURL = encodeURI(editURL);
        $.ajax({
            type: "Get",
