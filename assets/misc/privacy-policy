        $.ajax({
            type: "POST",
            url: editURL,
            dataType: "json",
            data: JSON.stringify({ strUserName: $('#inputUserName').val(), strPassword: $('#inputPassword').val() }),
            contentType: "application/json; charset=utf-8",
            success: function (data) {
