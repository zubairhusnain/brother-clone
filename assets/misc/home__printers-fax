    (function () {

        const toggleBttn = document.querySelector('.toggle-arrow');
        const printerNav = document.querySelector('.collapsible-nav');

        function showNav() {
            toggleBttn.classList.add('invert-text');
            printerNav.classList.add('visible');
        };

        function hideNav() {
            toggleBttn.classList.remove('invert-text');
            printerNav.classList.remove('visible', 'invert-text');
        }

        //On click, add visible class to the nav if the nav does not already have it. Else remove class visible.
        toggleBttn.addEventListener("click", function () {
            if (!printerNav.classList.contains('visible')) {
                showNav();
            }
            else {
                hideNav();
            }
        });

        const sliderCarousel = document.querySelector(".printer-nav"),
            docBody = document.querySelector("body"),
            firstTile = document.querySelectorAll(".product-tile")[0];

        let isDragStart = false, isDragging = false, prevPageX, prevScrollLeft, positionDiff;

        //Function to check what is in viewport
        function isInViewport(element) {
            const rect = element.getBoundingClientRect();
            return (
                rect.top >= 0 &&
                rect.left >= 0 &&
                rect.bottom <= (window.innerHeight || document.documentElement.clientHeight) &&
                rect.right <= (window.innerWidth || document.documentElement.clientWidth)
            );
        }

        const dragStart = (e) => {
            //Update variables on mousedown event
            isDragStart = true;
            prevPageX = e.pageX || e.touches[0].pageX;
            prevScrollLeft = sliderCarousel.scrollLeft;
        }

        const dragging = (e) => {
            //scroll carousel items left with mouse pointer
            //console.log(e.pageX);
            if (!isDragStart) return;
            e.preventDefault();
            isDragging = true;
            //prevent carousel from lagging when a user swipes through 
            sliderCarousel.classList.add("dragging");
            positionDiff = (e.pageX || e.touches[0].pageX) - prevPageX;
            sliderCarousel.scrollLeft = prevScrollLeft - positionDiff;
            showHiddenArrows();
        }

        const dragStop = (e) => {
            isDragStart = false;
            //Return carousel to normal smooth scrolling behavior
            sliderCarousel.classList.remove("dragging");

            //Slider will only drag if a user interacts, otherwise it won't call autoSlide. This to prevent dragging on click of a carousel item
            if (!isDragging) return;
            isDragging = false;
            autoSlide();
        }

        sliderCarousel.addEventListener("mousedown", dragStart);
        sliderCarousel.addEventListener("touchstart", dragStart);

        sliderCarousel.addEventListener("mousemove", dragging);
        sliderCarousel.addEventListener("touchmove", dragging);

        sliderCarousel.addEventListener("mouseup", dragStop);
        sliderCarousel.addEventListener("mouseleave", dragStop);
        sliderCarousel.addEventListener("touchend", dragStop);

    })();
</script>
