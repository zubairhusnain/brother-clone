          messageLocation.innerHTML = ""; // Clear previous messages
          messageLocation.appendChild(errorMessage);
        }
      } else {
        showError(searchText);
      }
    });
  }

  // Clear messages on clear button click
  if (clearButton) {
    clearButton.addEventListener("click", function () {
      successMessage.remove();
      errorMessage.remove();
