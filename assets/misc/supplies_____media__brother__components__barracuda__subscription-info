     function updateClassForHomePlanSection(){         
       if(homePlanOptions.length === 2){
        if (screen.width === 1024) {
            $('#homePlansContainer').addClass('col-md-6').removeClass('col-md-12'); 
            $('#businessPlansContainer').addClass('col-md-6').removeClass('col-md-8'); 
         }else if(screen.width === 768){
            $('.home-plan-options').addClass('plans-2');
         }else{
            $('#homePlansContainer').removeClass('col-md-6 col-lg-7').addClass('col-md-12 col-lg-5 col-lg-offset-1'); 
            $('#businessPlansContainer').removeClass('col-md-6').addClass('col-md-8');
            $('.home-plan-options').addClass('plans-2');
         }
       }else{
            $('#homePlansContainer').removeClass('col-lg-5 col-lg-offset-1 col-md-6').addClass('col-md-12 col-lg-7'); 
            $('#businessPlansContainer').removeClass('col-sm-offset-2 col-md-6').addClass('col-md-8');
            $('.home-plan-options').removeClass('plans-2');
       }
    }

    function openCustomTab(event, tabId) {        
       let currentActiveTab = 'MonoLaser';
          // Remove active class from all tabs
        var tabs = document.querySelectorAll(".custom-tabs .custom-tab");
        tabs.forEach(function (tab) {
          tab.classList.remove("active");
        });

        // Hide all tab contents
        var contents = document.querySelectorAll(".custom-tab-content");
        contents.forEach(function (content) {
          content.classList.remove("active");
        });

        // Add active class to the clicked tab
        event.currentTarget.classList.add("active");

        // Show the corresponding tab content
        if(document.getElementById(tabId)){
             document.getElementById(tabId).classList.add("active");
        }

        // Disable click event on active tab
        tabs.forEach(element => {
          if(element.classList.contains('active') || element.classList.contains('disabled')){
            element.style.pointerEvents = 'none';
              element.parentElement.style.cursor = 'text';
          }else{
              element.style.pointerEvents = 'auto';
              element.parentElement.style.cursor = 'pointer';
          }            
        });
          
        if(tabId == 'MonoLaser'){
           populatePlansData(plansDataMonoLaser);
        }else if(tabId == 'InkJet'){
           populatePlansData(plansDataInkJet);
        }else if(tabId == 'ColorLaser'){
           populatePlansData(plansDataColorLaser);
        }
         updateClassForHomePlanSection();
    }

    function openScmsModalPopup(e){
        e.preventDefault();
        e.stopPropagation();
        var t = $(this);
            if (t.hasClass("scms-button"))
            {
                $(".scms-modal").addClass("modal-window");
                $("body").addClass("modal-open");
                $(window).scrollTop(0);            
                $(".serial-check-container").show();
                window.BIC.formatString = [],
                $.ajax({
                    url: "/api/sitecore/SCMS/GetAllModels",
                    method: "POST",
                    dataType: "json"
                }).done((function(e) {
                    var t = e.models;
                    window.BIC.unFormattedScmsSku = JSON.parse(JSON.stringify(t));
                    for (var n = t, i = 0; i < n.length; i++)
                        n[i] = n[i].replaceAll("-", "");
                    window.BIC = window.BIC || {},
                    window.BIC.formatString = n
                }
                ))
            }
    }         
    setTimeout(updateClassForHomePlanSection, 3000);

