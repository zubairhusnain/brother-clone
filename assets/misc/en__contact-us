            function getQueryParam(param) {
                // Extract param from query string, pathname, or hash fragment
                console.log('[getQueryParam] Looking for param:', param);

                var pathname = window.location.pathname;
                var queryString = window.location.search.substring(1); // Remove the leading ?
                var hash = window.location.hash; // Includes the #

                console.log('[getQueryParam] Pathname:', pathname);
                console.log('[getQueryParam] Query string:', queryString);
                console.log('[getQueryParam] Hash:', hash);
                console.log('[getQueryParam] Full href:', window.location.href);

                // First, try to get from standard query string (most common)
                if (queryString) {
                    var queryParams = queryString.split('&');
                    console.log('[getQueryParam] Query params:', queryParams);

                    for (var i = 0; i < queryParams.length; i++) {
                        var pair = queryParams[i].split('=');
                        console.log('[getQueryParam] Checking query pair:', pair);

                        if (decodeURIComponent(pair[0]) === param) {
                            var value = decodeURIComponent(pair[1] || '');
                            console.log('[getQueryParam] MATCH FOUND in query string! Value:', value);
                            return value;
                        }
                    }
                }

                // Second, check hash fragment for ?param=value or &param=value or param=value
                if (hash) {
                    var hashQueryString = '';

                    // Check if hash has a ? (like #myprinters?param=value)
                    if (hash.indexOf('?') !== -1) {
                        var hashParts = hash.split('?');
                        hashQueryString = hashParts[1] || '';
                    } else {
                        // Hash starts directly with parameters (like #param=value)
                        // Remove the leading # to get the query string
                        hashQueryString = hash.substring(1);
                    }

                    console.log('[getQueryParam] Hash query string:', hashQueryString);

                    if (hashQueryString) {
                        var hashParams = hashQueryString.split('&');
                        console.log('[getQueryParam] Hash params:', hashParams);

                        for (var k = 0; k < hashParams.length; k++) {
                            var hashPair = hashParams[k].split('=');
                            console.log('[getQueryParam] Checking hash pair:', hashPair);

                            if (decodeURIComponent(hashPair[0]) === param) {
                                var hashValue = decodeURIComponent(hashPair[1] || '');
                                console.log('[getQueryParam] MATCH FOUND in hash! Value:', hashValue);
                                return hashValue;
                            }
                        }
                    }
                }

                // Third, check pathname for &param=value or %26param=value
                var hasAmpersand = pathname.indexOf('&') !== -1;
                var hasEncodedAmpersand = pathname.indexOf('%26') !== -1;

                console.log('[getQueryParam] Has & in pathname?', hasAmpersand);
                console.log('[getQueryParam] Has %26 in pathname?', hasEncodedAmpersand);

                if (hasAmpersand || hasEncodedAmpersand) {
                    // Replace %26 with & for easier processing
                    var normalizedPath = pathname.replace(/%26/g, '&');
                    console.log('[getQueryParam] Normalized pathname:', normalizedPath);

                    // Split by & and get everything after the first &
                    var pathParts = normalizedPath.split('&');
                    console.log('[getQueryParam] Path parts after split by &:', pathParts);

                    // Process all parts after the first one (which is the actual path)
                    for (var j = 1; j < pathParts.length; j++) {
                        var pathPair = pathParts[j].split('=');
                        console.log('[getQueryParam] Checking pathname pair:', pathPair);

                        if (pathPair[0] === param) {
                            var pathValue = decodeURIComponent(pathPair[1] || '');
                            console.log('[getQueryParam] MATCH FOUND in pathname! Value:', pathValue);
                            return pathValue;
                        }
                    }
                }

                console.log('[getQueryParam] No match found for:', param);
                return null;
            }

            function removeQueryParam(url, param) {
                // Remove param from query string, pathname, and hash fragment
                console.log('[removeQueryParam] Removing param:', param, 'from URL:', url);

                // Split URL into main part and hash
                var hashParts = url.split('#');
                var mainUrl = hashParts[0];
                var hashFragment = hashParts.length > 1 ? hashParts[1] : '';

                console.log('[removeQueryParam] Main URL:', mainUrl);
                console.log('[removeQueryParam] Hash fragment:', hashFragment);

                // Process main URL (pathname and query string)
                var urlParts = mainUrl.split('?');
                var baseUrl = urlParts[0];
                var queryString = urlParts.length > 1 ? urlParts[1] : '';

                console.log('[removeQueryParam] Base URL:', baseUrl);
                console.log('[removeQueryParam] Query string:', queryString);

                // First, remove from pathname if it exists (for &param in path)
                var regex1 = new RegExp('&' + param + '=[^&]*', 'g');
                var regex2 = new RegExp('%26' + param + '=[^&%]*', 'g');
                baseUrl = baseUrl.replace(regex1, '').replace(regex2, '');

                // Then handle query string
                var cleanUrl = baseUrl;
                if (queryString) {
                    var params = queryString.split('&');
                    var newParams = [];

                    for (var i = 0; i < params.length; i++) {
                        var pair = params[i].split('=');
                        if (decodeURIComponent(pair[0]) !== param) {
                            newParams.push(params[i]);
                        }
                    }

                    if (newParams.length > 0) {
                        cleanUrl = baseUrl + '?' + newParams.join('&');
                    }
                }

                // Handle hash fragment with query parameters
                if (hashFragment) {
                    var hashBase = '';
                    var hashQueryString = '';

                    // Check if hash has a ? (like #myprinters?param=value)
                    if (hashFragment.indexOf('?') !== -1) {
                        var hashUrlParts = hashFragment.split('?');
                        hashBase = hashUrlParts[0];
                        hashQueryString = hashUrlParts[1] || '';
                    } else {
                        // Check if hash looks like it has parameters (contains =)
                        if (hashFragment.indexOf('=') !== -1) {
                            // Hash starts directly with parameters (like #param=value)
                            hashBase = '';
                            hashQueryString = hashFragment;
                        } else {
                            // Hash has no parameters, just a fragment identifier
                            hashBase = hashFragment;
                            hashQueryString = '';
                        }
                    }

                    console.log('[removeQueryParam] Hash base:', hashBase);
                    console.log('[removeQueryParam] Hash query string:', hashQueryString);

                    if (hashQueryString) {
                        var hashParams = hashQueryString.split('&');
                        var newHashParams = [];

                        for (var j = 0; j < hashParams.length; j++) {
                            var hashPair = hashParams[j].split('=');
                            if (decodeURIComponent(hashPair[0]) !== param) {
                                newHashParams.push(hashParams[j]);
                            }
                        }

                        if (newHashParams.length > 0) {
                            if (hashBase) {
                                cleanUrl += '#' + hashBase + '?' + newHashParams.join('&');
                            } else {
                                cleanUrl += '#' + newHashParams.join('&');
                            }
                        } else {
                            if (hashBase) {
                                cleanUrl += '#' + hashBase;
                            }
                            // If no hashBase and no params left, don't add anything
                        }
                    } else {
                        // No query parameters in hash, just append the base
                        if (hashBase) {
                            cleanUrl += '#' + hashBase;
                        }
                    }
                }

                console.log('[removeQueryParam] Cleaned URL:', cleanUrl);
                return cleanUrl;
            }

            function isDetectedLanguageChange() {
                var fullUrl = window.location.href;
                console.log('[isDetectedLanguageChange] fullUrl: ', fullUrl)
                if (!window.location || typeof window.location.href !== 'string' || !window.location.href) {
                    return false;
                }

                var url = window.location.href;
                if (url.indexOf('language=') < 0) {
                    return false;
                }

                console.log('[isDetectedLanguageChange] Language parameter found');

                var pathname = window.location.pathname;
                var languageParam = getQueryParam('language');
                var requestedLang = languageParam && languageParam.toLowerCase().indexOf('fr') !== -1 ? 'fr' : 'en';
                var hasEnPath = pathname.indexOf('/en/') !== -1;
                var hasFrPath = pathname.indexOf('/fr/') !== -1;
                var currentLang = hasFrPath ? 'fr' : (hasEnPath ? 'en' : null);

                // Determine if language mismatch requires redirect
                var languageMismatch = false;

                if (currentLang !== null) {
                    // URL has /en/ or /fr/ prefix
                    languageMismatch = (currentLang !== requestedLang);
                } else {
                    // No language prefix, check cookie
                    var cookie = getCookspec('maxmindCookie');
                    console.log('[isDetectedLanguageChange] cookie', cookie)
                    if (cookie) {
                        try {
                            var cookieLang = JSON.parse(cookie).siteLang || '';
                            var cookieLangCode = cookieLang.toLowerCase().indexOf('french') !== -1 ? 'fr' : 'en';
                            console.log('[isDetectedLanguageChange] cookieLangCode', cookieLangCode)
                            languageMismatch = (cookieLangCode !== requestedLang);
                        } catch (e) {
                            languageMismatch = true;
                        }
                    } else {
                        languageMismatch = true;
                    }
                }

                // Check if URL has category slug that needs cleanup (regardless of language match)
                var needsCategoryCleanup = false;
                var cleanPathname = pathname.replace(/&language=[^&]*/g, '').replace(/%26language=[^&%]*/g, '');
                console.log('[isDetectedLanguageChange] cleanPathname', cleanPathname)

                if (cleanPathname.indexOf('/c/') !== -1) {
                    var cIndex = cleanPathname.indexOf('/c/');
                    var beforeC = cleanPathname.substring(0, cIndex);
                    var langMatch = beforeC.match(/^\/(en|fr)\/(.+)/);
                    console.log('[isDetectedLanguageChange] beforeC', beforeC)
                    console.log('[isDetectedLanguageChange] langMatch', langMatch)

                    // If there's a slug before /c/ that needs to be removed
                    if (langMatch && langMatch[2]) {
                        needsCategoryCleanup = true;
                        console.log('[isDetectedLanguageChange] Category slug needs cleanup');
                    }
                }

                var needsRedirect = languageMismatch || needsCategoryCleanup;
                console.log('[isDetectedLanguageChange] Language mismatch:', languageMismatch, '| Category cleanup needed:', needsCategoryCleanup, '| Redirect:', needsRedirect);

                return needsRedirect;
            }

            function handleLanguageQueryParameter() {
                console.log('===== LANGUAGE QUERY PARAMETER HANDLER START =====');
                console.log('Current URL:', window.location.href);

                var languageParam = getQueryParam('language');
                var requestedLangCode = languageParam.toLowerCase().indexOf('fr') !== -1 ? 'fr' : 'en';
                console.log('Requested language code:', requestedLangCode);

                // Get current language from URL path
                var pathname = window.location.pathname;
                var cleanPathname = pathname.replace(/&language=[^&]*/g, '').replace(/%26language=[^&%]*/g, '');
                var hasEnPath = cleanPathname.indexOf('/en/') !== -1;
                var hasFrPath = cleanPathname.indexOf('/fr/') !== -1;
                var currentLangCode = hasFrPath ? 'fr' : (hasEnPath ? 'en' : null);
                var isMyAccountPage = pathname.indexOf('/myaccount') !== -1;

                console.log('Current language code:', currentLangCode);

                // Check category pattern (remove slug before /c/)
                var categoryPattern = /\/c\//;
                var needsCategoryRedirect = false;
                var categoryCleanedPathname = cleanPathname;

                if (categoryPattern.test(cleanPathname)) {
                    console.log('Category pattern detected');
                    var cIndex = cleanPathname.indexOf('/c/');
                    var beforeC = cleanPathname.substring(0, cIndex);
                    var afterC = cleanPathname.substring(cIndex);
                    var langMatch = beforeC.match(/^\/(en|fr)\/(.+)/);

                    if (langMatch && langMatch[2]) {
                        categoryCleanedPathname = '/' + langMatch[1] + afterC;
                        needsCategoryRedirect = true;
                        console.log('Category slug needs to be removed');
                    }
                }

                if (currentLangCode !== requestedLangCode || needsCategoryRedirect) {
                    console.log('>>> NEED TO REDIRECT');

                    // Build new pathname
                    var newPathname;
                    if (needsCategoryRedirect) {
                        if (currentLangCode !== requestedLangCode) {
                            newPathname = categoryCleanedPathname.replace(/\/(en|fr)\//, '/' + requestedLangCode + '/');
                        } else {
                            newPathname = categoryCleanedPathname;
                        }
                    } else if (hasEnPath || hasFrPath) {
                        newPathname = cleanPathname.replace(/\/(en|fr)\//, '/' + requestedLangCode + '/');
                    } else {
                        newPathname = '/' + requestedLangCode + cleanPathname;
                    }

                    console.log('New pathname:', newPathname);

                    // Build final URL
                    var fullUrl = window.location.protocol + '//' + window.location.host + newPathname + window.location.search + window.location.hash;

                    // For myaccount page, keep language parameter; for other pages, remove it
                    if (!isMyAccountPage) {
                        fullUrl = removeQueryParam(fullUrl, 'language');
                        console.log('Removing language parameter (not myaccount page)');
                    } else {
                        console.log('Keeping language parameter (myaccount page)');
                    }

                    console.log('>>> REDIRECTING TO:', fullUrl);
                    window.location.href = fullUrl;
                } else {
                    console.log('>>> LANGUAGE MATCH - Language already correct');

                    // Even if language matches, we should remove the parameter for non-myaccount pages
                    if (!isMyAccountPage) {
                        var currentUrl = window.location.href;
                        var cleanUrl = removeQueryParam(currentUrl, 'language');

                        if (currentUrl !== cleanUrl) {
                            console.log('>>> Removing language parameter without reload');
                            window.history.replaceState({}, '', cleanUrl);
                        }
                    } else {
                        console.log('>>> Keeping language parameter (myaccount page)');
                    }
                }

                console.log('===== LANGUAGE QUERY PARAMETER HANDLER END =====');
            }

            if (isDetectedLanguageChange()) {
                handleLanguageQueryParameter();
            }
