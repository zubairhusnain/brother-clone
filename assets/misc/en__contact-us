<script type='text/javascript'>
var myVar;
var h = 0;
var targetRight = 5;
var CallDelay = 10;
var moveDelta = 5;
var panel;

//Will get called by the engagement engine once "rn_Dialog_0" exists (means a chat has been offered)
function Determine(){
	h = -305;
	panel = document.getElementById("rn_Dialog_0")
	if(panel != null){
		panel.parentElement.style.zIndex = "101";
		myVar = setInterval(MovePanel, CallDelay );		
	}	
}

//Gets called repeatedly to slide the chat panel in the viewport. 
function MovePanel() {
    h += moveDelta;
    panel.style.right = h + "px";
    if(h >= targetRight){
		panel.style.right = targetRight + "px";
		clearInterval(myVar);
    }
}
</script> 

