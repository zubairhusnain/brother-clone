            function preventXSS(str) {
                let regex = new RegExp(/<(\"[^\"]*\"|'[^']*'|[^'\">])*>/)

                if (regex.test(str) == true) {
                    $('.load-more-container').hide();
                    return "";
                } else {
                    let specialSymbols = str.replace(/[-!$%^&*()_+|~=`{}[:;<>?,.@#\]]/g, ' ');
                    let newStr = specialSymbols.trim();
                    if (newStr.length > 0) {
                        return newStr;
                    } else {
                        return "";
                    }
                }
            }
