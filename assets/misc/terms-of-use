    function funLogInUser() {
        var editURL = "/api/user/loginform/signinuser";
        editURL = encodeURI(editURL);
        var emailRegex = /^[a-zA-Z][\w\+.-]*[a-zA-Z0-9]+@[a-zA-Z0-9][\w\.-]*\.[a-zA-Z][a-zA-Z\.]*[a-zA-Z]$/i;
