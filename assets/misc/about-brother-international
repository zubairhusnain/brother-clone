                    url: "/api/cxa/BrotherCart/GetTealiumProductID",
                    async: false,
                    data: prodSKUJSON,
                    success: function (data) {
                        $.each(data.product_sku, function (index, value) {
                            $(".SKU_" + value).attr("product_id", data.product_id[index])
                        });

                    }
