  // Disable other tabs
  function disableOtherTabs(selectedTabId) {
    tabs.forEach(tab => {
      if (!tab.onclick.toString().includes(selectedTabId)) {
        tab.classList.add("disabled");
        tab.setAttribute("tabindex", "-1"); // Optionally make it non-focusable
        tab.style.pointerEvents = "none"; // Disable clicking
        tab.style.opacity = "0.5"; // Indicate disabled state
      } else {
        tab.classList.remove("disabled");
        tab.removeAttribute("tabindex");
        tab.style.pointerEvents = "auto"; // Enable clicking
        tab.style.opacity = "1"; // Normal opacity
      }
    });
  }

